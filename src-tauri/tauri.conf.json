{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/v2/packages/cli/schema.json",
  "productName": "PowerEN",
  "version": "0.1.0",
  "identifier": "com.poweren.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PowerEN",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  },
  "plugins": {
    "sql": {
      "preload": {
        "db": "sqlite:poweren.db"
      }
    }
  }
}
